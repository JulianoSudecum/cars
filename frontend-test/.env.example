# ──────────────────────────────────────────────────────────────
# Configuração do assistente de IA (BFF Express)
# Copie este arquivo para `.env` e preencha a chave.
# ──────────────────────────────────────────────────────────────

# Chave da API Anthropic — OBRIGATÓRIA para o assistente de perfil.
# Obtenha em https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Modelo usado nas recomendações (opcional). Padrão: claude-opus-4-7.
# Para respostas mais rápidas/baratas, troque por claude-sonnet-4-6 ou claude-haiku-4-5.
ANTHROPIC_MODEL=claude-opus-4-7

# Porta do servidor BFF (opcional, padrão 3001).
PORT=3001
