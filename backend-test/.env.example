# ---- Aplicação ----
ENVIRONMENT=development

# ---- Banco de dados ----
# Dentro do docker-compose, o host é "db". Localmente (fora do compose) use "localhost".
DATABASE_URL=postgresql+asyncpg://cars:cars@db:5432/cars
POSTGRES_USER=cars
POSTGRES_PASSWORD=cars
POSTGRES_DB=cars
# Porta exposta no host para acesso externo ao banco (default 5433 evita
# conflito caso já exista um Postgres local na 5432).
DB_HOST_PORT=5433

# ---- Autenticação (JWT) ----
# Gere um valor forte em produção: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=troque-por-um-segredo-forte-de-no-minimo-32-bytes
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ---- Claude API (funcionalidade de IA) ----
# Sem a chave, a app sobe normalmente; apenas o endpoint de descrição responde 503.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
ANTHROPIC_MAX_TOKENS=600

# ---- CORS (front-end em outro domínio) ----
# Lista separada por vírgula. Vazio = nenhuma origem cross-origin permitida (deny-all).
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ---- Seed automático no boot do container ----
RUN_SEED=true
